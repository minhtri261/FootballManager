@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - Football Manager</title>

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">

    <style>
        body {
            font-family: 'Segoe UI', sans-serif;
            background-color: #f8f9fa;
        }

        /* Layout grid */
        .main-container {
            display: flex;
            height: 100vh;
            overflow: hidden;
        }

        /* Sidebar */
        .sidebar {
            width: 250px;
            background-color: #212529;
            color: white;
            transition: width 0.3s;
        }

        .sidebar.collapsed {
            width: 70px;
        }

        .sidebar .nav-link {
            color: #adb5bd;
            padding: 10px 20px;
            border-radius: 8px;
            transition: all 0.2s;
        }

        .sidebar .nav-link:hover,
        .sidebar .nav-link.active {
            background-color: #495057;
            color: white;
        }

        .sidebar .dropdown-toggle::after {
            float: right;
            margin-top: 8px;
        }

        .sidebar .nav-item i {
            width: 25px;
        }

        /* Content area */
        .content {
            flex: 1;
            overflow-y: auto;
            padding: 20px;
        }

        /* Toggle button */
        #toggleSidebar {
            background: none;
            border: none;
            color: white;
            font-size: 1.2rem;
        }

        .sidebar-header {
            padding: 15px;
            font-size: 1.2rem;
            background-color: #343a40;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        /* Collapsed tooltip */
        .sidebar.collapsed .nav-link span {
            display: none;
        }

        .sidebar.collapsed .dropdown-toggle::after {
            display: none;
        }

        .sidebar.collapsed .sidebar-header span {
            display: none;
        }


    </style>
</head>

<body>
    <div class="main-container">
        <!-- Sidebar -->
        <nav id="sidebar" class="sidebar d-flex flex-column">
            <div class="sidebar-header">
                <span>⚽ Football Manager</span>
                <button id="toggleSidebar" title="Ẩn/Hiện menu"><i class="bi bi-list"></i></button>
            </div>

            <ul class="nav flex-column mt-2">
                <!-- Admin Manager -->
                <li class="nav-item">
                    <a class="nav-link dropdown-toggle text-white" data-bs-toggle="collapse" href="#adminMenu" role="button" aria-expanded="false">
                        <i class="bi bi-gear"></i><span>Admin Manager</span>
                    </a>
                    <ul class="collapse list-unstyled ps-4" id="adminMenu">
                        <li><a class="nav-link" asp-controller="Clubs" asp-action="Index"><i class="bi bi-shield"></i><span>Clubs</span></a></li>
                        <li><a class="nav-link" asp-controller="Tournaments" asp-action="Index"><i class="bi bi-trophy"></i><span>Tournaments</span></a></li>
                        <li><a class="nav-link" asp-controller="Footballers" asp-action="Index"><i class="bi bi-person-badge"></i><span>Footballers</span></a></li>
                    </ul>
                </li>

                <!-- In Game -->
                <li class="nav-item mt-2">
                    <a class="nav-link dropdown-toggle text-white" data-bs-toggle="collapse" href="#gameMenu" role="button" aria-expanded="false">
                        <i class="bi bi-controller"></i><span>In Game</span>
                    </a>
                    <ul class="collapse list-unstyled ps-4" id="gameMenu">
                        <li><a class="nav-link" asp-controller="MyTeam" asp-action="Index"><i class="bi bi-people"></i><span>My Team</span></a></li>
                        <li><a class="nav-link" asp-controller="MyTournament" asp-action="Index"><i class="bi bi-trophy-fill"></i><span>My Tournament</span></a></li>
                        <li><a class="nav-link" asp-controller="TransferMarket" asp-action="Index"><i class="bi bi-cash-coin"></i><span>Transfer Market</span></a></li>
                    </ul>
                </li>
            </ul>
        </nav>

        <!-- Content -->
        <div class="content">
            <div class="container-fluid">
                @RenderBody()
            </div>
        </div>
    </div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        const sidebar = document.getElementById('sidebar');
        const toggleBtn = document.getElementById('toggleSidebar');

        toggleBtn.addEventListener('click', () => {
            sidebar.classList.toggle('collapsed');
        });
    </script>

    @RenderSection("Scripts", required: false)

    <!-- Game Phase Button -->
    <button id="gamePhaseBtn" class="btn btn-primary rounded-pill shadow-lg px-4 py-2"
            style="position: fixed; bottom: 25px; right: 25px; z-index: 9999; display: none;">
        <span id="gamePhaseText">Đang tải...</span>
    </button>

    <script>
        const phaseBtn = document.getElementById("gamePhaseBtn");
        const phaseText = document.getElementById("gamePhaseText");
        const apiBase = "https://localhost:7088/api";

        async function loadGameState() {
            try {
                const res = await fetch(`${apiBase}/game/state`);
                if (!res.ok) throw new Error("Không thể tải trạng thái game.");
                const data = await res.json();
                updatePhaseButton(data.state.currentPhase);
            } catch (err) {
                console.error(err);
            }
        }

        function updatePhaseButton(phase) {
            switch (phase) {
                case 0:
                    phaseText.textContent = "🎮 Bắt đầu trò chơi";
                    phaseBtn.onclick = () => nextPhase();
                    break;
                case 1:
                    phaseText.textContent = "✅ Chốt đội hình mùa này";
                    phaseBtn.onclick = () => nextPhase();
                    break;
                case 2:
                    phaseText.textContent = "⚽ Trận đấu tiếp theo";
                    phaseBtn.onclick = () => nextMatch();
                    break;
                case 3:
                    phaseText.textContent = "🏁 Kết thúc mùa giải";
                    phaseBtn.onclick = () => nextPhase();
                    break;
                default:
                    phaseText.textContent = "Không rõ giai đoạn";
                    phaseBtn.onclick = null;
                    break;
            }
            phaseBtn.style.display = "block";
        }

        async function nextPhase() {
            if (!confirm("Bạn có chắc muốn chuyển sang giai đoạn tiếp theo?")) return;
            try {
                const res = await fetch(`${apiBase}/game/next-phase`, { method: "POST" });
                if (!res.ok) throw new Error("API lỗi");
                const data = await res.json();
                alert(data.message);
                updatePhaseButton(data.state.currentPhase);
            } catch (err) {
                alert("Lỗi khi chuyển giai đoạn.");
                console.error(err);
            }
        }

        async function nextMatch() {
            // TODO: Khi bạn tạo API riêng cho trận đấu, gọi ở đây.
            alert("⚽ Giả lập: Trận đấu tiếp theo (API chưa có).");
        }

        loadGameState();
    </script>

</body>
</html>

