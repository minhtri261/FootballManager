@model FootballManagerMVC.Models.Footballer
@{
    ViewData["Title"] = "Player Detail";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-4">
    <h2 class="mb-4 text-info fw-bold">🧍 Chi tiết cầu thủ</h2>

    @if (Model == null)
    {
        <div class="alert alert-warning">Không tìm thấy cầu thủ này.</div>
    }
    else
    {
        <div class="card border-0 shadow-lg rounded-4 p-4">
            <div class="d-flex align-items-center mb-3">
                <img src="/images/player.png" alt="Player Avatar" class="me-3 rounded-circle border" style="width:80px;height:80px;">
                <div>
                    <h3 class="fw-bold mb-1">@Model.Name</h3>
                    <span class="text-muted">@Model.Position</span>
                </div>
            </div>

            <hr />

            @if (ViewBag.Offers != null && ((List<TransferOfferModel>)ViewBag.Offers).Any())
            {
                <div class="alert alert-info mt-3">
                    <h5 class="fw-bold mb-2">💰 Lời đề nghị chuyển nhượng</h5>
                    <table class="table table-bordered table-striped">
                        <thead>
                            <tr>
                                <th>CLB gửi</th>
                                <th>Giá trị (€)</th>
                                <th>Trạng thái</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var offer in (List<TransferOfferModel>)ViewBag.Offers)
                            {
                                <tr>
                                    <td>@offer.ToClubId</td>
                                    <td>@offer.TransferFee.ToString("N0")</td>
                                    <td>
                                        @if (offer.Status == "Pending")
                                        {
                                            <span class="badge bg-warning text-dark">Đang chờ</span>
                                        }
                                        else if (offer.Status == "Accepted")
                                        {
                                            <span class="badge bg-success">Đã chấp nhận</span>
                                        }
                                        else if (offer.Status == "Rejected")
                                        {
                                            <span class="badge bg-danger">Từ chối</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="alert alert-secondary mt-3">
                    ⚽ Cầu thủ này chưa có lời đề nghị chuyển nhượng nào.
                </div>
            }


            <div class="row mb-3">
                <div class="col-md-6">
                    <p><strong>🎂 Tuổi:</strong> @Model.Age</p>
                    <p><strong>📊 Chỉ số tổng:</strong> <span class="fw-bold text-primary">@Model.Quality</span></p>
                    <p><strong>📅 Hợp đồng:</strong> @Model.ContractYears năm</p>
                </div>
                <div class="col-md-6">
                    <p><strong>🏆 QBV:</strong> @Model.AwardQBV</p>
                    <p><strong>🥈 QBB:</strong> @Model.AwardQBB</p>
                    <p><strong>🥉 QBĐ:</strong> @Model.AwardQBD</p>
                </div>
            </div>

            <div class="d-flex justify-content-between mt-4">
                <a asp-action="Players" class="btn btn-secondary">
                    <i class="bi bi-arrow-left"></i> Quay lại
                </a>
                <div>
                    <form asp-action="RenewContract" method="post" class="d-inline">
                        <input type="hidden" name="footballerId" value="@Model.Id" />
                        <select name="additionalYears" class="form-select me-2" style="width:120px;">
                            <option value="1">+1 năm</option>
                            <option value="2">+2 năm</option>
                            <option value="3">+3 năm</option>
                            <option value="4">+4 năm</option>
                        </select>
                        <button type="submit" class="btn btn-outline-success me-2 btn-renew">
                            <i class="bi bi-pencil-square"></i> Gia hạn hợp đồng
                        </button>
                    </form>
                    <a href="#" class="btn btn-outline-danger">
                        <i class="bi bi-x-circle"></i> Chấm dứt hợp đồng
                    </a>
                </div>
            </div>

            

        </div>
    }
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }
</div>
