@model FootballManagerMVC.Models.Club
@{
    ViewData["Title"] = "My Club";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-4">
    <h2 class="mb-4 text-primary fw-bold">
        🏟️ Thông tin CLB của bạn
    </h2>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }
    @if (Model != null)
    {
        <div class="card border-0 shadow-lg rounded-4 p-4">
            <div class="d-flex align-items-center mb-3">
                <img src="/images/club-badge.png" alt="Club Badge" class="me-3" style="width:64px;height:64px;">
                <div>
                    <h3 class="fw-bold mb-1">@Model.Name</h3>
                    <span class="text-muted">@Model.Nation</span>
                </div>
            </div>

            <hr />

            <div class="row">
                <div class="col-md-6">
                    <p class="fs-5 mb-1"><strong>💰 Ngân sách:</strong> @Model.Money.ToString("N0") ₫</p>
                </div>
                <div class="col-md-6">
                    <p class="fs-5 mb-1"><strong>🏆 Thành tích:</strong></p>
                    <ul class="list-unstyled ps-3">
                        <li>🏆 League Cups: <strong>@Model.LeagueCups</strong></li>
                        <li>🥇 Champions Cups: <strong>@Model.ChampionsCups</strong></li>
                        <li>🏅 National Cups: <strong>@Model.NationalCups</strong></li>
                    </ul>
                </div>
            </div>

            <div class="mt-4">
                <a asp-controller="MyTeam" asp-action="Players" class="btn btn-lg btn-primary px-4">
                    <i class="bi bi-people-fill"></i> Xem danh sách cầu thủ
                </a>
                <form asp-action="StartGame" method="post">
                    <button type="submit" class="btn btn-lg btn-success px-4">
                        <i class="bi bi-play-fill"></i> Bắt đầu trò chơi
                    </button>
                </form>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-warning mt-3">
            Không tìm thấy thông tin CLB của bạn.
        </div>
    }
</div>
