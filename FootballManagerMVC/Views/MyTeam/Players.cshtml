@model List<FootballManagerMVC.Models.Footballer>
@{
    ViewData["Title"] = "My Players";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-4">
    <h2 class="mb-4 text-success fw-bold">
        👥 Danh sách cầu thủ của tôi
    </h2>

    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-info">
            Chưa có cầu thủ nào trong đội.
        </div>
    }
    else
    {
        <div class="card shadow-sm border-0 rounded-4">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-dark text-white">
                        <tr>
                            <th>Tên cầu thủ</th>
                            <th class="text-center">Tuổi</th>
                            <th class="text-center">Vị trí</th>
                            <th class="text-center">Chỉ số tổng</th>
                            <th class="text-end"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var p in Model)
                        {
                            <tr>
                                <td class="fw-semibold">@p.Name</td>
                                <td class="text-center">@p.Age</td>
                                <td class="text-center">@p.Position</td>
                                <td class="text-center fw-bold text-primary">@p.Quality</td>
                                <td class="text-end">
                                    <a asp-action="Detail" asp-route-id="@p.Id"
                                       class="btn btn-sm btn-outline-primary rounded-pill px-3">
                                        <i class="bi bi-eye-fill"></i> Xem
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>
