@model FootballManagerMVC.Models.Tournament
@using System.Text.Json
@{
    ViewData["Title"] = "Sửa giải đấu";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var rewardJson = Model?.RewardByRank != null
       ? JsonSerializer.Serialize(Model.RewardByRank)
       : "[]";
}

<h2>@ViewData["Title"]</h2>

<form asp-action="AdminEdit" method="post" id="tournamentForm">
    <input type="hidden" asp-for="Id" />

    <div class="mb-3">
        <label asp-for="Name" class="form-label">Tên giải đấu</label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="SeasonNumber" class="form-label">Mùa giải</label>
        <input asp-for="SeasonNumber" type="number" class="form-control" />
        <span asp-validation-for="SeasonNumber" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="TeamsCount" class="form-label">Số đội tham gia</label>
        <input asp-for="TeamsCount" type="number" class="form-control" />
        <span asp-validation-for="TeamsCount" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Type" class="form-label">Thể thức</label>
        <select asp-for="Type" class="form-select">
            <option value="League">League</option>
            <option value="Cup">Cup</option>
            <option value="C1">GroupStage</option>
        </select>
        <span asp-validation-for="Type" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="PlayersPerMatch" class="form-label">Số cầu thủ mỗi trận</label>
        <input asp-for="PlayersPerMatch" type="number" class="form-control" />
        <span asp-validation-for="PlayersPerMatch" class="text-danger"></span>
    </div>

    <!-- RewardByRank dynamic table -->
    <div class="mb-3">
        <label class="form-label">Thưởng theo thứ hạng</label>
        <table class="table table-sm table-bordered" id="rewardTable">
            <thead>
                <tr>
                    <th style="width:120px">Hạng</th>
                    <th>Số tiền</th>
                    <th style="width:120px">Hành động</th>
                </tr>
            </thead>
            <tbody>
                <!-- rows injected by JS -->
            </tbody>
        </table>

        <button type="button" class="btn btn-outline-primary btn-sm" id="addRewardBtn">Thêm hàng</button>
        <small class="form-text text-muted">Ví dụ JSON lưu: [{"rank":1,"money":2000},{"rank":2,"money":1500}]</small>
    </div>

    <!-- hidden field holds JSON string -->
    <input type="hidden" name="RewardByRank" id="RewardByRank" value='@Html.Raw(rewardJson)' />

    <button type="submit" class="btn btn-success">Lưu thay đổi</button>
    <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
</form>

@section Scripts {
    <script>
        (function () {
            const tableBody = document.querySelector("#rewardTable tbody");
            const addBtn = document.getElementById("addRewardBtn");
            const hiddenInput = document.getElementById("RewardByRank");
            const form = document.getElementById("tournamentForm");

            // parse existing JSON from hidden input (if any)
            let rewards = [];
            try {
                const raw = hiddenInput.value && hiddenInput.value.trim() ? hiddenInput.value : "[]";
                rewards = JSON.parse(raw);
                if (!Array.isArray(rewards)) rewards = [];
            } catch (e) {
                rewards = [];
            }

            function render() {
                tableBody.innerHTML = "";
                rewards.forEach((r, idx) => {
                    const tr = document.createElement("tr");

                    const tdRank = document.createElement("td");
                    tdRank.innerHTML = `<input name="rank" type="number" min="1" class="form-control form-control-sm" value="${r.rank ?? ""}" />`;

                    const tdMoney = document.createElement("td");
                    tdMoney.innerHTML = `<input name="money" type="number" min="0" class="form-control form-control-sm" value="${r.money ?? ""}" />`;

                    const tdAction = document.createElement("td");
                    tdAction.innerHTML = `<button type="button" class="btn btn-sm btn-danger remove-row">Xóa</button>`;

                    tr.appendChild(tdRank);
                    tr.appendChild(tdMoney);
                    tr.appendChild(tdAction);

                    tableBody.appendChild(tr);
                });

                if (rewards.length === 0) {
                    const tr = document.createElement("tr");
                    tr.innerHTML = `<td colspan="3" class="text-center text-muted">Chưa có thưởng nào — thêm bằng "Thêm hàng"</td>`;
                    tableBody.appendChild(tr);
                }
            }

            function collectFromTable() {
                const rows = Array.from(tableBody.querySelectorAll("tr"));
                const collected = [];
                for (const row of rows) {
                    const rankInput = row.querySelector('input[name="rank"]');
                    const moneyInput = row.querySelector('input[name="money"]');
                    if (!rankInput || !moneyInput) continue;
                    const rankVal = parseInt(rankInput.value || "0", 10);
                    const moneyVal = parseInt(moneyInput.value || "0", 10);
                    if (!isNaN(rankVal) && rankVal > 0) {
                        collected.push({ rank: rankVal, money: isNaN(moneyVal) ? 0 : moneyVal });
                    }
                }
                return collected;
            }

            addBtn.addEventListener("click", () => {
                rewards.push({ rank: "", money: "" });
                render();
            });

            tableBody.addEventListener("click", function (e) {
                if (e.target && e.target.classList.contains("remove-row")) {
                    const row = e.target.closest("tr");
                    const rows = Array.from(tableBody.querySelectorAll("tr"));
                    const idx = rows.indexOf(row);
                    if (idx >= 0) {
                        rewards.splice(idx, 1);
                        render();
                    }
                }
            });

            form.addEventListener("submit", function (e) {
                const collected = collectFromTable();
                hiddenInput.value = JSON.stringify(collected);
            });

            // initial render
            render();
        })();
    </script>
}
