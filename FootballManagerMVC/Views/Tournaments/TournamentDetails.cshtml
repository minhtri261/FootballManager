@model FootballManagerMVC.Models.Tournament

@{
    ViewData["Title"] = "Chi tiết giải đấu";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <div class="card shadow-sm p-4">
        <h2 class="mb-3 text-primary">@Model.Name (@Model.Type)</h2>
        <p><strong>Mùa giải:</strong> @Model.SeasonNumber</p>
        <p><strong>Số đội:</strong> @Model.TeamsCount</p>

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success">@TempData["Success"]</div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger">@TempData["Error"]</div>
        }

        <hr />
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h4 class="mb-0">Lịch thi đấu</h4>
            <div class="d-flex gap-2">
                <form method="post" asp-action="GenerateMatches">
                    <input type="hidden" name="id" value="@Model.Id" />
                    <button type="submit" class="btn btn-success">
                        <i class="bi bi-calendar-plus"></i> Tạo lịch thi đấu
                    </button>
                </form>
                <a asp-action="ListMatches" asp-route-id="@Model.Id" class="btn btn-outline-primary">
                    <i class="bi bi-list-ul"></i> Xem danh sách
                </a>
            </div>
        </div>

        @if (Model.Matches?.Any() == true)
        {
            <table class="table table-striped table-bordered align-middle">
                <thead class="table-light">
                    <tr>
                        <th>STT</th>
                        <th>Đội chủ nhà</th>
                        <th>Đội khách</th>
                        <th>Tỷ số</th>
                        <th>Kết quả</th>
                    </tr>
                </thead>
                <tbody>
                    @for (int i = 0; i < Model.Matches.Count; i++)
                    {
                        var match = Model.Matches[i];
                        <tr>
                            <td>@(i + 1)</td>
                            <td>@match.HomeClub?.Name</td>
                            <td>@match.AwayClub?.Name</td>
                            <td>@($"{match.HomeGoals ?? 0}-{match.AwayGoals ?? 0}")</td>
                            <td>@match.Result</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <p class="text-muted fst-italic">Chưa có lịch thi đấu nào được tạo.</p>
        }


        <hr />
        <h4>Phần thưởng</h4>
        @if (Model.RewardByRank?.Any() == true)
        {
            <ul class="list-group mb-3">
                @foreach (var reward in Model.RewardByRank)
                {
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        <span>Hạng @reward.Rank</span>
                        <span class="badge bg-info text-dark">@reward.Money.ToString("N0") VNĐ</span>
                    </li>
                }
            </ul>
        }
        else
        {
            <p class="text-muted fst-italic">Chưa có dữ liệu phần thưởng</p>
        }

        <hr />
        <h4>Câu lạc bộ tham dự</h4>
        @if (Model.Clubs?.Any() == true)
        {
            <table class="table table-hover table-bordered align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Tên CLB</th>
                        <th>Điểm</th>
                        <th>Hạng</th>
                        <th>Bàn thắng</th>
                        <th>Bàn thua</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var c in Model.Clubs)
                    {
                        <tr>
                            <td>@c.ClubName</td>
                            <td>@c.Points</td>
                            <td>@c.Rank</td>
                            <td>@c.GoalsFor</td>
                            <td>@c.GoalsAgainst</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <p class="text-muted fst-italic">Chưa có dữ liệu CLB</p>
        }

        <hr />
        <h4>➕ Thêm CLB vào giải đấu</h4>
        <form asp-action="AdminAddClub" method="post" class="mt-2">
            <input type="hidden" name="tournamentId" value="@Model.Id" />
            <div class="input-group mb-3">
                <input type="number" name="clubId" class="form-control" placeholder="Nhập ID CLB..." required />
                <button type="submit" class="btn btn-primary">Thêm CLB</button>
            </div>
        </form>
    </div>
</div>
