@model FootballManagerMVC.Models.Tournament
@{
    ViewData["Title"] = "Xóa giải đấu";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2>@ViewData["Title"]</h2>

<h4>Bạn có chắc chắn muốn xóa giải đấu này?</h4>
<hr />

<dl class="row">
    <dt class="col-sm-2">Tên</dt>
    <dd class="col-sm-10">@Model.Name</dd>

    <dt class="col-sm-2">Mùa giải</dt>
    <dd class="col-sm-10">@Model.SeasonNumber</dd>

    <dt class="col-sm-2">Số đội</dt>
    <dd class="col-sm-10">@Model.TeamsCount</dd>

    <dt class="col-sm-2">Thể thức</dt>
    <dd class="col-sm-10">@Model.Type</dd>

    <dt class="col-sm-2">Cầu thủ/trận</dt>
    <dd class="col-sm-10">@Model.PlayersPerMatch</dd>
</dl>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Xóa</button>
    <a asp-action="Index" class="btn btn-secondary">Hủy</a>
</form>
