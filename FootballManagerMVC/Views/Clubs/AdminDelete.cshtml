@model FootballManagerMVC.Models.Club
@{
    ViewData["Title"] = "Xoá CLB";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
}

<div class="container mt-5 col-md-6">
    <div class="card shadow p-4 border-danger">
        <h3 class="text-danger text-center mb-4">⚠️ Xác nhận xoá CLB</h3>
        <p class="text-center fs-5">Bạn có chắc chắn muốn xoá <b>@Model.Name</b> không?</p>

        <form asp-action="DeleteConfirmed" class="text-center">
            <input type="hidden" asp-for="Id" />
            <button type="submit" class="btn btn-danger me-2">Xoá</button>
            <a asp-action="Index" class="btn btn-secondary">Huỷ</a>
        </form>
    </div>
</div>
