@model IEnumerable<FootballManagerMVC.Models.Club>

@{
    ViewData["Title"] = "Danh sách CLB";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2 class="mb-4 text-center">🏆 Danh sách Câu lạc bộ</h2>

<div class="d-flex justify-content-end mb-3">
    <a asp-action="AdminCreate" class="btn btn-success">
        <i class="bi bi-plus-circle"></i> Thêm CLB mới
    </a>
</div>

<table class="table table-striped table-hover align-middle text-center shadow-sm">
    <thead class="table-dark">
        <tr>
            <th>Tên đội</th>
            <th>Quốc gia</th>
            <th>💰 Tiền</th>
            <th>🏆 League Cups</th>
            <th>🥇 Champions Cups</th>
            <th>🏅 National Cups</th>
            <th>⚙️ Chất lượng tập</th>
            <th>🤖 Bot</th>
            <th>Thao tác</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var c in Model)
        {
            <tr>
                <td>@c.Name</td>
                <td>@c.Nation</td>
                <td>@c.Money.ToString("N0")</td>
                <td>@c.LeagueCups</td>
                <td>@c.ChampionsCups</td>
                <td>@c.NationalCups</td>
                <td>@c.TrainingQuality</td>
                <td>@(c.IsBot ? "✅" : "❌")</td>
                <td>
                    <a asp-action="ClubDetail" asp-route-id="@c.Id" class="btn btn-sm btn-info text-white me-1">
                        <i class="bi bi-eye"></i> Xem
                    </a>
                    <a asp-action="AdminEdit" asp-route-id="@c.Id" class="btn btn-sm btn-warning me-1">
                        <i class="bi bi-pencil-square"></i> Sửa
                    </a>
                    <a asp-action="AdminDelete" asp-route-id="@c.Id" class="btn btn-sm btn-danger">
                        <i class="bi bi-trash"></i> Xoá
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>
