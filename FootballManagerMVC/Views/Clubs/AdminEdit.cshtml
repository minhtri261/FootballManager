@model FootballManagerMVC.Models.Club
@{
    ViewData["Title"] = "Sửa CLB";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4 col-md-6">
    <h2 class="mb-4 text-center text-warning">✏️ Sửa thông tin CLB</h2>

    <form asp-action="AdminEdit" class="shadow p-4 rounded bg-light">
        <input type="hidden" asp-for="Id" />

        <div class="mb-3">
            <label class="form-label">Tên đội</label>
            <input asp-for="Name" class="form-control" />
        </div>
        <div class="mb-3">
            <label class="form-label">Quốc gia</label>
            <input asp-for="Nation" class="form-control" />
        </div>
        <div class="mb-3">
            <label class="form-label">Tiền</label>
            <input asp-for="Money" class="form-control" />
        </div>
        <div class="mb-3">
            <label class="form-label">Chất lượng tập</label>
            <input asp-for="TrainingQuality" class="form-control" />
        </div>
        <div class="mb-3">
            <label class="form-label">Số cup League</label>
            <input asp-for="LeagueCups" class="form-control" />
        </div>
        <div class="mb-3">
            <label class="form-label">Số Cup C1</label>
            <input asp-for="ChampionsCups" class="form-control" />
        </div>
        <div class="mb-3">
            <label class="form-label">Số Cup Quốc gia</label>
            <input asp-for="NationalCups" class="form-control" />
        </div>
        <div class="form-check mb-3">
            <input asp-for="IsBot" class="form-check-input" type="checkbox" />
            <label class="form-check-label">Là Bot?</label>
        </div>

        <div class="d-flex justify-content-between">
            <button type="submit" class="btn btn-warning w-50 me-2 text-white">Cập nhật</button>
            <a asp-action="Index" class="btn btn-secondary w-50">Huỷ</a>
        </div>
    </form>
</div>
