@model FootballManagerMVC.Models.Club
@{
    ViewData["Title"] = "Chi tiết CLB";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4 col-md-6">
    <div class="card shadow p-4">
        <h2 class="text-center mb-3 text-primary">🏟️ Chi tiết CLB</h2>
        <table class="table table-bordered">
            <tr><th>Tên</th><td>@Model.Name</td></tr>
            <tr><th>Quốc gia</th><td>@Model.Nation</td></tr>
            <tr><th>Tiền</th><td>@Model.Money.ToString("N0")</td></tr>
            <tr><th>Cúp League</th><td>@Model.LeagueCups</td></tr>
            <tr><th>Cúp C1</th><td>@Model.ChampionsCups</td></tr>
            <tr><th>Cúp Quốc gia</th><td>@Model.NationalCups</td></tr>
            <tr><th>Chất lượng tập</th><td>@Model.TrainingQuality</td></tr>
            <tr><th>Là Bot</th><td>@(Model.IsBot ? "✅" : "❌")</td></tr>
        </table>

        <div class="d-flex justify-content-between mt-3">
            <a asp-action="AdminEdit" asp-route-id="@Model.Id" class="btn btn-warning text-white">
                <i class="bi bi-pencil-square"></i> Sửa
            </a>
            <a asp-action="Index" class="btn btn-secondary">
                <i class="bi bi-arrow-left"></i> Quay lại
            </a>
        </div>
    </div>
</div>
