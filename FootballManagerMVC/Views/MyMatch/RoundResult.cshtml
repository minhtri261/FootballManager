@model FootballManagerMVC.Models.RoundResultViewModel

@{
    ViewData["Title"] = "Kết quả vòng đấu";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <h2 class="text-center mb-4">KẾT QUẢ VÒNG ĐẤU</h2>

    <div class="row">
        <div class="col-md-5">
            <h4>Tỷ số các trận</h4>
            @foreach (var m in Model.Matches)
            {
                <div class="card mb-2 shadow-sm">
                    <div class="card-body d-flex justify-content-between align-items-center p-2">
                        <span class="text-end" style="flex:1"><strong>@m.HomeClubId</strong></span>
                        <span class="badge bg-primary mx-3" style="font-size: 1.1rem;">@m.HomeGoals - @m.AwayGoals</span>
                        <span class="text-start" style="flex:1"><strong>@m.AwayClubId</strong></span>
                    </div>
                </div>
            }
        </div>

        <div class="col-md-7">
            <h4>Bảng xếp hạng</h4>
            <div class="table-responsive">
                <table class="table table-bordered">
                    <thead>
                        <tr class="bg-dark text-white">
                            <th>#</th>
                            <th>CLB</th>
                            <th>Trận</th>
                            <th>T-H-B</th>
                            <th>Hiệu số</th>
                            <th>Điểm</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var s in Model.Standings)
                        {
                            <tr class="@(s.Status == "Eliminated" ? "table-secondary text-muted" : "")">
                                <td>@s.Rank</td>
                                <td>
                                    <strong>@s.ClubName</strong>
                                    @* CHỈ hiển thị badge "Bị loại" nếu Status từ server trả về là Eliminated *@
                                    @if (s.Status == "Eliminated")
                                    {
                                        <span class="badge bg-danger">Bị loại</span>
                                    }
                                </td>
                                <td>@s.Played</td>
                                <td>@s.Won - @s.Drawn - @s.Lost</td>
                                <td>@(s.GoalsFor - s.GoalsAgainst)</td>
                                <td class="fw-bold">@s.Points</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="text-center mt-4">
        <button class="btn btn-success btn-lg shadow" onclick="nextMatch()">
            TIẾP TỤC ĐẾN TRẬN TIẾP THEO
        </button>
    </div>
</div>