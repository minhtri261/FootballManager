@model FootballManagerMVC.Models.MyMatchViewModel
@{
    ViewData["Title"] = "Chọn đội hình";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <h2 class="mb-4 text-center">Chuẩn bị thi đấu</h2>

    @if (Model.Match == null)
    {
        <div class="alert alert-info text-center">
            Vòng này bạn được nghỉ. <br />
            <a class="btn btn-primary mt-2" asp-action="MyResult" asp-route-tournamentId="@ViewBag.CurrentTournamentId">Tiếp tục</a>
        </div>
    }
    else
    {
        <div class="row">
            <div class="col-md-7">
                <div class="card shadow-sm p-3 mb-4">
                    <h4 class="border-bottom pb-2">Đội hình của tôi</h4>

                    <div class="row mb-3 mt-2">
                        <div class="col-md-6">
                            <label class="fw-bold">Chọn sơ đồ chiến thuật:</label>
                            <select id="formation" name="Formation" class="form-select border-primary">
                                <option value="3-2-1">3-2-1 (3 CB - 2 MF - 1 CF)</option>
                                <option value="2-3-1">2-3-1 (2 CB - 3 MF - 1 CF)</option>
                                <option value="2-2-2">2-2-2 (2 CB - 2 MF - 2 CF)</option>
                                <option value="1-3-2">1-3-2 (1 CB - 3 MF - 2 CF)</option>
                            </select>
                        </div>
                    </div>

                    <h5>Cầu thủ khả dụng</h5>
                    <div class="list-group mb-3" style="max-height: 250px; overflow-y: auto; border: 1px solid #dee2e6;">
                        @foreach (var p in Model.MyPlayers)
                        {
                            <div class="list-group-item d-flex justify-content-between align-items-center">
                                <span><strong class="text-primary">@p.Position</strong> – @p.Name</span>
                                <button class="btn btn-sm btn-primary" type="button"
                                        onclick="addToLineup('@p.Id','@p.Name','@p.Position')">
                                    Chọn
                                </button>
                            </div>
                        }
                    </div>

                    <form asp-action="SubmitLineup" method="post" onsubmit="return validateLineup()">
                        <input type="hidden" name="TournamentId" value="@ViewBag.CurrentTournamentId" />
                        <input type="hidden" name="MatchId" value="@Model.Match.MatchId" />

                        <h5 class="text-success mt-3">Đội hình ra sân (Đã chọn)</h5>
                        <ul class="list-group mb-3" id="myLineup" style="min-height: 100px; border: 2px dashed #28a745; padding: 10px;">
                        </ul>

                        <button class="btn btn-success btn-lg w-100 shadow">XÁC NHẬN & BẮT ĐẦU</button>
                    </form>
                </div>
            </div>

            <div class="col-md-5">
                <div class="card shadow-sm p-3 bg-light">
                    <h4 class="text-danger">Đối thủ</h4>
                    <div class="d-flex justify-content-between align-items-center">
                        <h5>@Model.OpponentLineup.ClubName</h5>
                        <span class="badge bg-dark">@Model.OpponentLineup.ClubNation</span>
                    </div>
                    <p>Sơ đồ đối thủ: <strong>@Model.OpponentLineup.Formation</strong></p>
                    <hr />
                    <div class="opponent-list">
                        @foreach (var p in Model.OpponentLineup.Players)
                        {
                            <div class="p-2 mb-2 border rounded bg-white">
                                <span class="fw-bold text-secondary">@p.Position</span> – @p.Name
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script>
        function addToLineup(id, name, pos) {
            const list = document.getElementById("myLineup");

            // 1. Kiểm tra trùng
            if ([...list.children].some(li => li.dataset.id === id)) {
                alert("Cầu thủ này đã được chọn!");
                return;
            }

            // 2. Tạo phần tử li
            const li = document.createElement("li");
            li.className = "list-group-item d-flex justify-content-between align-items-center mb-1 shadow-sm";
            li.dataset.id = id;
            li.dataset.position = pos;

            li.innerHTML = `
                <span><b class="text-success">${pos}</b> – ${name}</span>
                <input type="hidden" name="PlayerIds" value="${id}" />
                <button type="button" class="btn btn-sm btn-outline-danger" onclick="this.parentElement.remove()">X</button>
            `;

            list.appendChild(li);
        }

        function validateLineup() {
            const formationStr = document.getElementById("formation").value;
            const parts = formationStr.split("-").map(Number); // [3, 2, 1]
            const players = [...document.querySelectorAll("#myLineup li")];

            const count = { GK: 0, CB: 0, MF: 0, CF: 0 };

            players.forEach(p => {
                const pos = p.dataset.position;
                if (pos === "GK") count.GK++;
                else if (pos === "CB") count.CB++;
                else if (pos === "CF") count.CF++;
                else if (["DM", "CM", "AM"].includes(pos)) count.MF++;
            });

            // Logic kiểm tra đội hình 7 người (Sân 7)
            if (players.length !== 7) {
                alert("Đội hình phải có đủ 7 người!");
                return false;
            }
            if (count.GK !== 1) {
                alert("Bắt buộc phải có 1 Thủ môn (GK)!");
                return false;
            }
            if (count.CB !== parts[0]) {
                alert(`Sơ đồ ${formationStr} cần ${parts[0]} Hậu vệ (CB). Bạn đang có ${count.CB}.`);
                return false;
            }
            if (count.MF !== parts[1]) {
                alert(`Sơ đồ ${formationStr} cần ${parts[1]} Tiền vệ (DM/CM/AM). Bạn đang có ${count.MF}.`);
                return false;
            }
            if (count.CF !== parts[2]) {
                alert(`Sơ đồ ${formationStr} cần ${parts[2]} Tiền đạo (CF). Bạn đang có ${count.CF}.`);
                return false;
            }

            return true;
        }
    </script>
}