@model FootballManagerMVC.Models.MyMatchViewModel
@{
    ViewData["Title"] = "Trận đấu";
}

<div class="container mt-5 text-center">
    <div class="card shadow-sm p-5">
        <h2 class="text-uppercase text-primary">Trận đấu tiếp theo</h2>
        <hr />
        @if (Model.Match != null)
        {
            <p class="lead">Bạn có một trận đấu sắp diễn ra với đối thủ <strong>@Model.OpponentLineup.ClubName</strong>.</p>
            <div class="mt-4">
                <a asp-action="Lineup" asp-route-tournamentId="@Model.Match.TournamentId" class="btn btn-success btn-lg">
                    Đến trang chọn đội hình ngay
                </a>
            </div>
        }
        else
        {
            <div class="alert alert-info">Vòng đấu này bạn không có lịch thi đấu.</div>
            <a asp-action="MyResult" asp-route-tournamentId="@ViewBag.TournamentId" class="btn btn-primary">Xem kết quả</a>
        }
    </div>
</div>

