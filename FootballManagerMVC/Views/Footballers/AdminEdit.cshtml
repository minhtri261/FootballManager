@model FootballManagerMVC.Models.Footballer
@{
    ViewData["Title"] = "Sửa cầu thủ";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var clubs = ViewBag.Clubs as List<FootballManagerMVC.Models.Club>;
}

<h2>Sửa cầu thủ</h2>

<form asp-action="AdminEdit" method="post" class="mt-3">
    <input type="hidden" asp-for="Id" />
    <div class="mb-3">
        <label>Tên cầu thủ</label>
        <input asp-for="Name" class="form-control" />
    </div>
    <div class="mb-3">
        <label>Tuổi</label>
        <input asp-for="Age" class="form-control" />
    </div>
    <div class="mb-3">
        <label>Quốc tịch</label>
        <input asp-for="Nation" class="form-control" />
    </div>
    <div class="mb-3">
        <label>Vị trí</label>
        <select asp-for="Position" class="form-select">
            <option>GK</option>
            <option>CB</option>
            <option>DM</option>
            <option>CM</option>
            <option>AM</option>
            <option>CF</option>
        </select>
    </div>
    <div class="mb-3">
        <label>Câu lạc bộ</label>
        <select asp-for="ClubId" class="form-select">
            <option value="">-- Thất nghiệp (Free Agent) --</option>
            @foreach (var c in clubs)
            {
                <option value="@c.Id" selected="@(c.Id == Model.ClubId)">
                    @c.Name
                </option>
            }
        </select>
    </div>
    <div class="mb-3">
        <label>Chất lượng</label>
        <input asp-for="Quality" class="form-control" />
    </div>
    <div class="mb-3">
        <label>Hợp đồng (năm)</label>
        <input asp-for="ContractYears" class="form-control" />
    </div>
    <div class="mb-3">
        <label>Trạng thái</label>
        <input asp-for="Status" class="form-control" />
    </div>
    <div class="form-check">
        <input asp-for="IsTransferListed" class="form-check-input" />
        <label class="form-check-label">Đang trên thị trường chuyển nhượng miễn phí</label>
    </div>

    <button type="submit" class="btn btn-warning mt-3">Lưu thay đổi</button>
    <a asp-action="Index" class="btn btn-secondary mt-3">Hủy</a>
</form>
