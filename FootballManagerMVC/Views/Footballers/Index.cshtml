@model IEnumerable<FootballManagerMVC.Models.Footballer>
@{
    ViewData["Title"] = "Danh sách cầu thủ";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2>@ViewData["Title"]</h2>

<p>
    <a asp-action="AdminCreate" class="btn btn-primary"><i class="bi bi-plus-lg"></i> Thêm cầu thủ</a>
</p>

<form method="get" asp-action="Index" class="d-flex gap-2 mb-3">
    <input type="text" name="keyword" value="@ViewBag.Keyword" class="form-control w-25" placeholder="Tìm cầu thủ..." />

    <select name="sortBy" class="form-select w-auto">
        <option value="Name" selected="@("Name" == (ViewBag.SortBy ?? "Name"))">Tên</option>
        <option value="Age" selected="@("Age" == ViewBag.SortBy)">Tuổi</option>
        <option value="Nation" selected="@("Nation" == ViewBag.SortBy)">Quốc tịch</option>
        <option value="Quality" selected="@("Quality" == ViewBag.SortBy)">Chất lượng</option>
    </select>

    <select name="desc" class="form-select w-auto">
        <option value="false" selected="@(!((bool)ViewBag.Desc))">Tăng dần</option>
        <option value="true" selected="@((bool)ViewBag.Desc)">Giảm dần</option>
    </select>

    <select name="clubId" class="form-select w-auto">
        <option value="">Tất cả CLB</option>
        @foreach (var c in ViewBag.Clubs)
        {
            <option value="@c.Id" selected="@(ViewBag.ClubId != null && (int)ViewBag.ClubId == c.Id)">
                @c.Name
            </option>
        }
    </select>

    <button type="submit" class="btn btn-primary"><i class="bi bi-search"></i> Lọc</button>
</form>

<table class="table table-bordered table-hover">
    <thead>
        <tr>
            <th>Tên</th>
            <th>Tuổi</th>
            <th>Quốc tịch</th>
            <th>Vị trí</th>
            <th>CLB</th>
            <th>Thao tác</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var f in Model)
        {
            <tr>
                <td>@f.Name</td>
                <td>@f.Age</td>
                <td>@f.Nation</td>
                <td>@f.Position</td>
                <td>@(string.IsNullOrEmpty(f.ClubName) ? "Thất nghiệp" : f.ClubName)</td>
                <td>
                    <a asp-action="FootballerDetails" asp-route-id="@f.Id">Chi tiết</a> |
                    <a asp-action="AdminEdit" asp-route-id="@f.Id">Sửa</a> |
                    <a asp-action="AdminDelete" asp-route-id="@f.Id">Xóa</a>
                </td>
            </tr>
        }
    </tbody>
</table>

<!-- ✅ Phân trang -->
@if (ViewBag.TotalPages > 1)
{
    <nav>
        <ul class="pagination">
            @for (int i = 1; i <= ViewBag.TotalPages; i++)
            {
                <li class="page-item @(i == ViewBag.PageNumber ? "active" : "")">
                    <a class="page-link"
                       asp-action="Index"
                       asp-route-pageNumber="@i"
                       asp-route-keyword="@ViewBag.Keyword"
                       asp-route-sortBy="@ViewBag.SortBy"
                       asp-route-desc="@ViewBag.Desc"
                       asp-route-clubId="@ViewBag.ClubId">
                        @i
                    </a>
                </li>
            }
        </ul>
    </nav>
}
